---
import '@/styles/globals.css';
import { Badge } from '@/components/ui/badge';

interface Props {
  // When used directly in `.astro` pages, the title / description come
  // through as individual props. When used via the `layout:` frontmatter key
  // in a `.md` / `.mdx` page, Astro wraps the page's frontmatter into a
  // single `frontmatter` prop. Accept both shapes so a single layout works
  // either way.
  title?: string;
  description?: string;
  frontmatter?: { title?: string; description?: string };
}

const props = Astro.props as Props;
const title = props.title ?? props.frontmatter?.title ?? 'Docs';
const description = props.description ?? props.frontmatter?.description;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

// Sidebar tree. Sections + items. `href` matches against the current URL
// path (without trailing slash) to set the active state. Future pages (and
// the auto-generated configuration reference) live alongside as muted /
// disabled stubs to show the intended IA without faking content.
const sidebar: Array<{
  heading: string;
  items: Array<{ label: string; href?: string; soon?: boolean }>;
}> = [
  {
    heading: 'Getting Started',
    items: [
      { label: 'Overview', href: `${base}/` },
      { label: 'Install', href: `${base}/install/` },
    ],
  },
  {
    heading: 'Reference',
    items: [
      { label: 'Configuration', soon: true },
      { label: 'NebariApp CRD', soon: true },
      { label: 'Report schema', soon: true },
    ],
  },
  {
    heading: 'Operating',
    items: [
      { label: 'Dashboard tour', soon: true },
      { label: 'Grafana integration', soon: true },
    ],
  },
];

const isActive = (href?: string) =>
  href != null && href.replace(/\/$/, '') === (`${base}${currentPath}`.replace(/\/$/, '') || '/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · Provenance Collector</title>
    {description && <meta name="description" content={description} />}
    <link
      rel="icon"
      href="https://raw.githubusercontent.com/nebari-dev/nebari-design/main/symbol/favicon.ico"
    />
    <!--
      Pagefind: static client-side search. Index is generated post-`astro
      build` by the pagefind CLI (see package.json `build` script) and lives
      at `<base>/pagefind/`. Skip loading these files in `astro dev` — they
      don't exist yet, and a 404 would noise up the console.
    -->
    {import.meta.env.PROD && (
      <>
        <link rel="stylesheet" href={`${base}/pagefind/pagefind-ui.css`} />
        <script is:inline src={`${base}/pagefind/pagefind-ui.js`} defer></script>
        <script is:inline set:html={`window.addEventListener('DOMContentLoaded', () => { if (window.PagefindUI) new PagefindUI({ element: '#search', basePath: '${base}/pagefind/', showSubResults: true, showImages: false, resetStyles: false }); });`}></script>
      </>
    )}
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <header class="sticky top-0 z-20 border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/70">
      <div class="mx-auto flex h-14 max-w-6xl items-center gap-6 px-6">
        <a href={`${base}/`} class="flex shrink-0 items-center gap-2.5 text-sm font-semibold">
          <img
            src="https://raw.githubusercontent.com/nebari-dev/nebari-design/main/logo-mark/horizontal/standard/Nebari-Logo-Horizontal-Lockup.png"
            alt="Nebari"
            class="h-6"
          />
          <span class="text-muted-foreground">/</span>
          <span>Provenance Collector</span>
        </a>

        <nav class="hidden items-center gap-5 text-sm md:flex">
          <a
            href={`${base}/`}
            class="text-foreground/80 transition-colors hover:text-foreground"
          >
            Docs
          </a>
          <a
            href="https://nebari-dev.github.io/nebari-design/"
            class="text-muted-foreground transition-colors hover:text-foreground"
          >
            Design system
          </a>
        </nav>

        <div class="ml-auto flex items-center gap-3">
          {import.meta.env.PROD && (
            <div id="search" class="pagefind-search hidden md:block"></div>
          )}
          <a
            href="https://github.com/nebari-dev/nebari-provenance-collector-pack"
            aria-label="GitHub repository"
            class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-border text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
          >
            <svg viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
            </svg>
          </a>
        </div>
      </div>
    </header>

    <div class="mx-auto flex max-w-6xl gap-8 px-6">
      <aside class="sticky top-14 hidden h-[calc(100vh-3.5rem)] w-56 shrink-0 overflow-y-auto border-r border-border py-8 pr-6 md:block">
        <nav aria-label="Docs navigation" class="space-y-6 text-sm">
          {sidebar.map((section) => (
            <div>
              <h3 class="mb-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
                {section.heading}
              </h3>
              <ul class="space-y-0.5">
                {section.items.map((item) => (
                  <li>
                    {item.href ? (
                      <a
                        href={item.href}
                        class:list={[
                          'block rounded-md px-2.5 py-1.5 transition-colors',
                          isActive(item.href)
                            ? 'bg-primary/10 font-medium text-primary'
                            : 'text-foreground/70 hover:bg-muted hover:text-foreground',
                        ]}
                      >
                        {item.label}
                      </a>
                    ) : (
                      <span
                        class="flex items-center justify-between rounded-md px-2.5 py-1.5 text-muted-foreground/60"
                        title="Stub — would land when this skeleton graduates into the template"
                      >
                        <span>{item.label}</span>
                        {item.soon && <Badge variant="secondary">soon</Badge>}
                      </span>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      </aside>

      <main class="min-w-0 max-w-3xl flex-1 py-10">
        <slot />
      </main>
    </div>

    <footer class="mt-16 border-t border-border">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-6 text-xs text-muted-foreground">
        <span>BSD-3-Clause · Built by Nebari</span>
        <a
          href="https://github.com/nebari-dev/nebari-design"
          class="transition-colors hover:text-foreground"
          >Powered by nebari-design</a
        >
      </div>
    </footer>
  </body>
</html>
